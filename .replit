modules = ["nodejs-20", "swift-5.8"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx react-native start --port 8080 --reset-cache"
waitForPort = 8080

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["yarn", "start", "--port", "8080"]
